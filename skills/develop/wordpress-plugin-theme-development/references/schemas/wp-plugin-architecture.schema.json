{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WordPress Plugin Architecture Manifest",
  "type": "object",
  "required": ["type", "name", "textDomain", "mainFile", "php", "services", "hooks", "security"],
  "properties": {
    "type": { "type": "string", "enum": ["plugin"] },
    "name": { "type": "string" },
    "textDomain": { "type": "string" },
    "mainFile": { "type": "string" },
    "namespace": { "type": "string" },
    "php": {
      "type": "object",
      "required": ["minimumVersion", "strictTypes"],
      "properties": {
        "minimumVersion": { "type": "string" },
        "strictTypes": { "type": "boolean" },
        "composerOptional": { "type": "boolean" }
      }
    },
    "services": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["class", "responsibility"],
        "properties": {
          "class": { "type": "string" },
          "responsibility": { "type": "string" }
        }
      }
    },
    "hooks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type", "callback"],
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string", "enum": ["action", "filter"] },
          "callback": { "type": "string" },
          "priority": { "type": "integer" }
        }
      }
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["handle", "context"],
        "properties": {
          "handle": { "type": "string" },
          "context": { "type": "string" }
        }
      }
    },
    "security": {
      "type": "object",
      "required": ["nonce", "capability", "sanitize", "escape"],
      "properties": {
        "nonce": { "type": "boolean" },
        "capability": { "type": "boolean" },
        "sanitize": { "type": "boolean" },
        "escape": { "type": "boolean" }
      }
    }
  }
}
