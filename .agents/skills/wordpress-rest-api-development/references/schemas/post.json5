// ============================================================
// WordPress REST API — Post（文章）Schema
// 端點：GET /wp/v2/posts?_embed
// 官方文件：https://developer.wordpress.org/rest-api/reference/posts/
// ============================================================
{
  // === 基本欄位 ===
  id: 123,                                        // integer, 唯一識別碼（read only）
  date: "2025-01-15T10:30:00",                    // string|null, 發佈日期（站台時區）
  date_gmt: "2025-01-15T02:30:00",                // string|null, 發佈日期（GMT）
  modified: "2025-01-20T08:00:00",                // string, 最後修改（站台時區，read only）
  modified_gmt: "2025-01-20T00:00:00",            // string, 最後修改（GMT，read only）
  slug: "my-first-post",                          // string, URL slug（唯一於同類型）
  status: "publish",                              // string: publish | future | draft | pending | private
  type: "post",                                   // string, 文章類型（read only）
  link: "https://cms.example.com/my-first-post/", // string (uri), WordPress 原始連結（read only）

  // === 內容欄位（皆為 object，含 rendered 子欄位）===
  title: {
    rendered: "我的第一篇文章",                     // string, HTML rendered 標題
    // raw: "我的第一篇文章",                       // ⚠️ 僅 edit context 才有
  },
  content: {
    rendered: "<p>文章內容 HTML...</p>",            // string, HTML rendered 內容
    protected: false,                              // boolean, 是否密碼保護
    // raw: "文章原始內容",                         // ⚠️ 僅 edit context
    // block_version: 2,                           // ⚠️ 僅 edit context
  },
  excerpt: {
    rendered: "<p>文章摘要...</p>",                 // string, HTML rendered 摘要
    protected: false,                              // boolean
  },

  // === 識別與 meta ===
  guid: {
    rendered: "https://cms.example.com/?p=123",    // string, 全域唯一識別（read only）
  },
  author: 1,                                       // integer, 作者 User ID
  featured_media: 456,                             // integer, 特色圖片 Media ID（0 = 無圖片）
  comment_status: "open",                          // string: open | closed
  ping_status: "closed",                           // string: open | closed
  sticky: false,                                   // boolean, 是否置頂文章
  template: "",                                    // string, 佈景模板檔名（空字串 = 預設）
  format: "standard",                              // string: standard | aside | chat | gallery | link | image | quote | status | video | audio
  meta: {},                                        // object, 自訂 meta 欄位（依 register_post_meta 設定）
  password: "",                                    // string, 密碼保護（⚠️ 僅 edit context）

  // === 分類法（Taxonomy）===
  categories: [1, 3],                              // integer[], 分類 ID 陣列
  tags: [5, 8],                                    // integer[], 標籤 ID 陣列

  // === Yoast SEO 擴充（需安裝 Yoast SEO 外掛）===
  yoast_head: "<title>文章標題 | 網站名</title><meta name=\"description\" content=\"...\"/>", // string, SEO 完整 HTML blob
  yoast_head_json: {
    title: "文章標題 | 網站名",                     // string, SEO 標題
    description: "文章摘要描述",                     // string, SEO 描述
    robots: {
      index: "index",                              // string, 搜尋引擎索引指令
      follow: "follow",                            // string, 連結追蹤指令
      "max-snippet": "max-snippet:-1",
      "max-image-preview": "max-image-preview:large",
      "max-video-preview": "max-video-preview:-1",
    },
    canonical: "https://example.com/my-first-post/", // string, canonical URL（⚠️ Headless 需覆寫為前端網域）
    og_locale: "zh_TW",                            // string, Open Graph 語系
    og_type: "article",                            // string, Open Graph 類型
    og_title: "文章標題",                           // string, OG 標題
    og_description: "文章摘要",                     // string, OG 描述
    og_url: "https://example.com/my-first-post/",  // string, OG URL
    og_site_name: "網站名稱",                       // string, OG 站名
    article_published_time: "2025-01-15T02:30:00+00:00", // string, 發佈時間（ISO 8601）
    article_modified_time: "2025-01-20T00:00:00+00:00",  // string, 修改時間（ISO 8601）
    og_image: [
      {
        width: 1200,                               // integer, 圖片寬度
        height: 630,                               // integer, 圖片高度
        url: "https://cms.example.com/wp-content/uploads/og.jpg", // string, 圖片 URL
        type: "image/jpeg",                        // string, MIME type（可選）
      },
    ],
    twitter_card: "summary_large_image",           // string, Twitter Card 類型
    twitter_title: "文章標題",                      // string
    twitter_description: "文章摘要",                // string
    twitter_image: "https://cms.example.com/wp-content/uploads/og.jpg", // string
    schema: {
      "@context": "https://schema.org",            // JSON-LD Schema.org
      "@graph": [],                                // array, Schema 節點
    },
  },

  // === _embedded（使用 ?_embed 查詢參數時出現）===
  _embedded: {
    // 作者資料
    author: [
      {
        id: 1,                                     // integer
        name: "Admin",                             // string, 顯示名稱
        url: "",                                   // string, 個人網站
        description: "網站管理員",                   // string, 個人簡介
        link: "https://cms.example.com/author/admin/", // string
        slug: "admin",                             // string
        avatar_urls: {
          "24": "https://secure.gravatar.com/avatar/...?s=24", // string, 24px 頭像
          "48": "https://secure.gravatar.com/avatar/...?s=48", // string, 48px 頭像
          "96": "https://secure.gravatar.com/avatar/...?s=96", // string, 96px 頭像
        },
      },
    ],

    // 特色圖片
    "wp:featuredmedia": [
      {
        id: 456,                                   // integer
        date: "2025-01-10T12:00:00",               // string
        slug: "featured-image",                    // string
        type: "attachment",                        // string, 固定為 "attachment"
        link: "https://cms.example.com/featured-image/",
        title: { rendered: "特色圖片" },            // object
        author: 1,                                 // integer
        caption: { rendered: "<p>圖片說明</p>" },   // object
        alt_text: "圖片替代文字",                    // string, ⭐ SEO 重要
        media_type: "image",                       // string: image | video | audio | file
        mime_type: "image/jpeg",                   // string
        source_url: "https://cms.example.com/wp-content/uploads/2025/01/hero.jpg", // string, ⭐ 前端最常用
        media_details: {
          width: 1920,                             // integer, 原始寬度
          height: 1080,                            // integer, 原始高度
          file: "2025/01/hero.jpg",                // string, 相對路徑
          sizes: {
            thumbnail: {
              file: "hero-150x150.jpg",
              width: 150,
              height: 150,
              mime_type: "image/jpeg",
              source_url: "https://cms.example.com/wp-content/uploads/2025/01/hero-150x150.jpg",
            },
            medium: {
              file: "hero-300x169.jpg",
              width: 300,
              height: 169,
              mime_type: "image/jpeg",
              source_url: "https://cms.example.com/wp-content/uploads/2025/01/hero-300x169.jpg",
            },
            large: {
              file: "hero-1024x576.jpg",
              width: 1024,
              height: 576,
              mime_type: "image/jpeg",
              source_url: "https://cms.example.com/wp-content/uploads/2025/01/hero-1024x576.jpg",
            },
            full: {
              file: "hero.jpg",
              width: 1920,
              height: 1080,
              mime_type: "image/jpeg",
              source_url: "https://cms.example.com/wp-content/uploads/2025/01/hero.jpg",
            },
          },
        },
      },
    ],

    // 分類法 terms
    "wp:term": [
      // [0] = categories（分類）
      [
        {
          id: 1,
          link: "https://cms.example.com/category/news/",
          name: "新聞",                             // string, 分類名稱
          slug: "news",                            // string
          taxonomy: "category",                    // string, 固定 "category"
        },
        {
          id: 3,
          link: "https://cms.example.com/category/announcement/",
          name: "公告",
          slug: "announcement",
          taxonomy: "category",
        },
      ],
      // [1] = tags（標籤）
      [
        {
          id: 5,
          link: "https://cms.example.com/tag/drone/",
          name: "無人機",                            // string, 標籤名稱
          slug: "drone",                           // string
          taxonomy: "post_tag",                    // string, 固定 "post_tag"
        },
      ],
    ],
  },

  // === _links（HATEOAS 風格，API 自動產生，前端通常不需要）===
  _links: {
    self: [{ href: "https://cms.example.com/wp-json/wp/v2/posts/123" }],
    collection: [{ href: "https://cms.example.com/wp-json/wp/v2/posts" }],
    author: [{ embeddable: true, href: "https://cms.example.com/wp-json/wp/v2/users/1" }],
    "wp:featuredmedia": [{ embeddable: true, href: "https://cms.example.com/wp-json/wp/v2/media/456" }],
    "wp:term": [
      { taxonomy: "category", embeddable: true, href: "https://cms.example.com/wp-json/wp/v2/categories?post=123" },
      { taxonomy: "post_tag", embeddable: true, href: "https://cms.example.com/wp-json/wp/v2/tags?post=123" },
    ],
  },
}
